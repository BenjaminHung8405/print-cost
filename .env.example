# ===== DATABASE CONFIGURATION =====
DB_USER=admin
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_16_CHARS
DB_NAME=printcost_db
DB_PORT=5432
DATABASE_URL=postgres://admin:CHANGE_ME_TO_STRONG_PASSWORD_MIN_16_CHARS@localhost:5432/printcost_db

# ===== APPLICATION CONFIGURATION =====
NODE_ENV=production
LOG_LEVEL=info

# ===== API & FRONTEND URLS =====
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8080

# Production (khi deploy, thay bằng domain thực)
# NEXT_PUBLIC_API_URL=https://api.printcost.local

# ===== BACKUP CONFIGURATION =====
# Google Drive hoặc iCloud path (nếu dùng rclone)
BACKUP_REMOTE=gdrive:/printcost-backups
BACKUP_RETENTION_DAYS=30

# ===== SECURITY =====
# JWT Secret (nếu dùng authentication)
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_MIN_32_CHARS

# ===== BANK CONFIGURATION FOR VIETQR (NAPAS-247) =====
# Dùng mã viết tắt tiêu chuẩn như MB, VCB, TCB, ACB, v.v.
BANK_ID=MB
BANK_ACCOUNT_NO=0000123456789
BANK_ACCOUNT_NAME=NGUYEN PHI HUNG

# ===== OPTIONAL: TAILSCALE / CLOUDFLARE TUNNEL =====
# TAILSCALE_AUTHKEY=tskey-xxxxxxx
# CLOUDFLARE_TUNNEL_TOKEN=xxxxx
