# ===== DEVELOPMENT DOCKERFILE FOR BACKEND (Node.js/Express) =====
FROM node:22-alpine
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@11.1.1

# Copy package manifests
COPY package.json pnpm-lock.yaml ./

# Install dependencies (--ignore-scripts avoids interactive prompts in Docker for esbuild/vitest)
RUN pnpm install --frozen-lockfile --ignore-scripts

EXPOSE 8080

# ts-node-dev hot-reload
CMD ["pnpm", "run", "dev"]
